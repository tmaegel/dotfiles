{{ if and (eq .hosttype "desktop") (eq .chezmoi.os "linux") -}}
[fedora]
image=fedora:44
additional_packages="{{- range .packages.distrobox.fedora -}} {{ . }} {{ end -}}"
init=false
nvidia=false
pull=true
root=false
replace=true
start_now=false
entry=false
init_hooks=ln -sf /usr/bin/distrobox-host-exec /usr/bin/bootc;
init_hooks=ln -sf /usr/bin/distrobox-host-exec /usr/bin/code;
init_hooks=ln -sf /usr/bin/distrobox-host-exec /usr/bin/docker-compose;
init_hooks=ln -sf /usr/bin/distrobox-host-exec /usr/bin/docker;
init_hooks=ln -sf /usr/bin/distrobox-host-exec /usr/bin/flatpak;
init_hooks=ln -sf /usr/bin/distrobox-host-exec /usr/bin/podman-compose;
init_hooks=ln -sf /usr/bin/distrobox-host-exec /usr/bin/podman;
{{ end -}}
