[
  {
    "context": "Workspace",
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-b": "workspace::ToggleLeftDock",
      "ctrl-B": "workspace::ToggleRightDock",
      "ctrl-E": "project_panel::Toggle",
      "ctrl-G": "git_panel::Toggle",
      "ctrl-tab": "tab_switcher::OpenInActivePane",
    },
  },
  {
    "context": "GitPanel",
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-down": "workspace::ActivatePaneDown",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-left": "workspace::ActivatePaneLeft",
      "ctrl-right": "workspace::ActivatePaneRight",
      "ctrl-up": "workspace::ActivatePaneUp",
    },
  },
  {
    "context": "ProjectPanel",
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-down": "workspace::ActivatePaneDown",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-left": "workspace::ActivatePaneLeft",
      "ctrl-right": "workspace::ActivatePaneRight",
      "ctrl-up": "workspace::ActivatePaneUp",
    },
  },
  {
    "context": "Editor",
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-b": "workspace::ToggleLeftDock",
      "ctrl-B": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "VimControl && !menu",
    "use_key_equivalents": true,
    "bindings": {
      // Put key bindings here if you want them to work in normal & visual mode.
    },
  },
  {
    "context": "vim_mode == normal && !menu",
    "use_key_equivalents": true,
    "bindings": {
      "*": "vim::SearchUnderCursor",
      "c a": "editor::ToggleCodeActions",
      "c d": "editor::Rename",
      "c f": "editor::Format",
      "ctrl-down": "workspace::ActivatePaneDown",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-left": "workspace::ActivatePaneLeft",
      "ctrl-right": "workspace::ActivatePaneRight",
      "ctrl-shift-down": "vim::ResizePaneDown",
      "ctrl-shift-h": "vim::ResizePaneLeft",
      "ctrl-shift-j": "vim::ResizePaneDown",
      "ctrl-shift-k": "vim::ResizePaneUp",
      "ctrl-shift-l": "vim::ResizePaneRight",
      "ctrl-shift-left": "vim::ResizePaneLeft",
      "ctrl-shift-right": "vim::ResizePaneRight",
      "ctrl-shift-up": "vim::ResizePaneUp",
      "ctrl-up": "workspace::ActivatePaneUp",
      "g d": "editor::GoToDefinition",
      "g D": "editor::GoToDefinitionSplit",
      "g i": "editor::GoToImplementation",
      "g I": "editor::GoToImplementationSplit",
      "g r": "editor::FindAllReferences",
      "g t": "editor::GoToTypeDefinition",
      "g T": "editor::GoToTypeDefinitionSplit",
      "h A": "git::Add",
      "h a": "git::StageAndNext",
      "h d": "editor::ToggleAllDiffHunks",
      "h D": "git::Diff",
      "h n": "editor::GoToHunk",
      "h N": "editor::GoToPreviousHunk",
      "h r": "git::Restore",
      "h R": "git::RestoreFile",
      "h u": "git::UnstageAndNext",
      "K": "editor::Hover",
      "space f b": "tab_switcher::OpenInActivePane",
      "space f f": "file_finder::Toggle",
      "space f g": "text_finder::Toggle",
      "space H": "git_panel::Toggle",
      "U": "vim::Redo",
      "x n": "editor::GoToDiagnostic",
      "x N": "editor::GoToPreviousDiagnostic",
      "x X": "diagnostics::Deploy",
      "x x": "diagnostics::DeployCurrentFile",
    },
  },
  {
    "context": "vim_mode == insert",
    "use_key_equivalents": true,
    "bindings": {
      "j j": "vim::NormalBefore",
      "j k": "vim::NormalBefore",
    },
  },
  {
    "context": "EmptyPane || SharedScreen",
    "use_key_equivalents": true,
    "bindings": {
      // Put key bindings here (in addition to the context above) if you want them to
      // work when no editor exists.
      "space f f": "file_finder::Toggle",
      "space f g": "text_finder::Toggle",
    },
  },
]
