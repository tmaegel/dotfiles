{{ if and (eq .hosttype "desktop") (eq .chezmoi.os "linux") -}}
#!/usr/bin/env bash

if [[ -z "${BW_SESSION}" ]]; then
	if command -v flatpak &> /dev/null; then
		exec flatpak run --command=bw com.bitwarden.desktop "$@"
	else
		exec bw "$@"
	fi
else
	if command -v flatpak &> /dev/null; then
		exec flatpak run --command=bw com.bitwarden.desktop "$@" --session "${BW_SESSION}"
	else
		exec bw "$@" --session "${BW_SESSION}"
	fi
fi
{{ end -}}