{{ if and (or (eq .hosttype "devcontainer") (eq .hosttype "wsl")) (eq .chezmoi.os "linux") -}}
#!/usr/bin/env bash

# -u: Treat unset variables as an error when substituting.
# -e: Exit immediately if a command exits with a non-zero status.
# -o pipefail: the return value of a pipeline is the status of the
#              last command to exit with a non-zero status.
set -eo pipefail

echo ">>> RUN $(basename "$0")"

{{ if eq .chezmoi.osRelease.id "ubuntu" -}}

if ! command -v apt > /dev/null; then
    echo "Skip: apt is not installed"
    exit 0
fi

sudo apt install -y {{ .packages.ubuntu | join " " }}
{{ else if eq .chezmoi.osRelease.id "fedora" -}}

if ! command -v dnf > /dev/null; then
    echo "Skip: dnf is not installed"
    exit 0
fi

sudo dnf install {{ .packages.fedora | join " " }}
{{ end -}}
{{ end -}}
