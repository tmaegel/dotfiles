{{ if or (eq .hosttype "wsl") (eq .hosttype "desktop") -}}
{
  "breadcrumbs.icons": false,
  "breadcrumbs.symbolPath": "off",
  "chat.fontSize": 16,
  "chat.viewSessions.orientation": "stacked",
  "editor.guides.indentation": true, // we try to make semantic highlighting look good
  "editor.minimap.enabled": false,
  "editor.overviewRulerBorder": false,
  "editor.renderFinalNewline": "on",
  "editor.rulers": [],
  "editor.scrollbar.horizontalScrollbarSize": 8,
  "editor.scrollbar.verticalScrollbarSize": 8,
  "editor.semanticHighlighting.enabled": true,
  "explorer.autoReveal": false,
  "extensions.autoCheckUpdates": true,
  "files.encoding": "utf8",
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "remote.autoForwardPorts": false,
  "terminal.integrated.allowChords": false,
  "terminal.integrated.fontFamily": "\"Hack Nerd Font\", monospace",
  "terminal.integrated.minimumContrastRatio": 1, // prevent VSCode from modifying the terminal colors
  "terminal.integrated.tabs.enabled": true,
  "update.mode": "none",
  "window.customTitleBarVisibility": "auto",
  "window.menuBarVisibility": "toggle",
  "window.titleBarStyle": "custom",
  "workbench.colorTheme": "One Dark Pro Darker",
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#23272E",
    "activityBar.activeBorder": "#23272E",
    "activityBar.activeFocusBorder": "#23272E",
    "activityBar.background": "#23272E",
    "activityBar.border": "#1E2227",
    "editorGroup.border": "#1E2227",
    "panel.border": "#1E2227",
    "panelTitle.activeBorder": "#23272e",
    "sideBar.background": "#1E2227",
    "statusBar.background": "#1E2227",
    "tab.activeBorder": "#23272E",
    "tab.border": "#1E2227",
    "tab.inactiveBackground": "#1E2227",
    "terminalOverviewRuler.border": "#23272e"
  },
  "workbench.activityBar.location": "top",
  "workbench.editor.editorActionsLocation": "titleBar",
  "workbench.editor.enablePreview": false,
  "workbench.startupEditor": "none",
  "workbench.tree.indent": 14
}
{{ end -}}
